# Fichier local de configuration (développement).
# Renseignez les clés/valeurs réelles avant exécution.

JWT_SECRET=change-me-in-prod
GOOGLE_API_KEY=
OPENAI_API_KEY=
LANGCHAIN_API_KEY=
LANGCHAIN_TRACING_V2=true
PAGEINDEX_API_KEY=
GROQ_API_KEY=

GPTCACHE_URL=http://localhost:8001
RIVAL_URL=http://localhost:8002
MONGODB_URI=mongodb://localhost:27017
POSTGRES_DSN=postgresql://postgres:postgres@localhost:5432/support_bot
GROQ_BASE_URL=https://api.groq.com/openai/v1

MAX_INPUT_CHARS=4000
MAX_SESSION_TURNS=10
FAITHFULNESS_THRESHOLD=0.7
COMPLETENESS_THRESHOLD=0.6
LOW_COMPLEXITY_MODEL=gemini-2.0-flash
HIGH_COMPLEXITY_MODEL=gemini-2.5-pro

RETRIEVAL_DOC_IDS=
RETRIEVAL_MAX_DOCS=20

DRIVE_FOLDER_ID=
GOOGLE_SERVICE_ACCOUNT_FILE=./secrets/google-service-account.json
DRIVE_SYNC_STATE_COLLECTION=sync_state
