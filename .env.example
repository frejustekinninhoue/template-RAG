# =============================================================================
# Production AI App - template unique multi-clients
# =============================================================================

# --- Auth / sécurité ----------------------------------------------------------
JWT_SECRET=change-me-in-prod

# --- Clés LLM -----------------------------------------------------------------
GOOGLE_API_KEY=
OPENAI_API_KEY=
GROQ_API_KEY=

# Observabilité LLM (LangSmith)
LANGCHAIN_API_KEY=
LANGCHAIN_TRACING_V2=true

# PageIndex
PAGEINDEX_API_KEY=

# --- Services -----------------------------------------------------------------
GPTCACHE_URL=http://gptcache:8001
RIVAL_URL=http://rival-service:8002
MONGODB_URI=mongodb://mongodb:27017
POSTGRES_DSN=postgresql://postgres:postgres@postgres:5432/support_bot

# Endpoints compatibles OpenAI
GROQ_BASE_URL=https://api.groq.com/openai/v1
OPENAI_BASE_URL=

# --- Tuning runtime ------------------------------------------------------------
MAX_INPUT_CHARS=4000
MAX_SESSION_TURNS=10
FAITHFULNESS_THRESHOLD=0.7
COMPLETENESS_THRESHOLD=0.6

# --- Sélection provider/modèle (agnostique client) ---------------------------
# provider: gemini | openai | groq | openai_compatible
LOW_COMPLEXITY_PROVIDER=gemini
LOW_COMPLEXITY_MODEL=gemini-2.0-flash

HIGH_COMPLEXITY_PROVIDER=gemini
HIGH_COMPLEXITY_MODEL=gemini-2.5-pro
# Exemples:
# HIGH_COMPLEXITY_PROVIDER=openai
# HIGH_COMPLEXITY_MODEL=gpt-4o
# HIGH_COMPLEXITY_PROVIDER=groq
# HIGH_COMPLEXITY_MODEL=llama-3.1-8b-instant

# Routeur query_intelligence (laisser vide => LOW_*)
QUERY_INTELLIGENCE_PROVIDER=
QUERY_INTELLIGENCE_MODEL=

# Recherche d'arbre (retrieval) et complétude
TREE_SEARCH_PROVIDER=gemini
TREE_SEARCH_MODEL=gemini-2.0-flash
COMPLETENESS_JUDGE_PROVIDER=gemini
COMPLETENESS_JUDGE_MODEL=gemini-2.0-flash

# Évaluation fidélité Ragas (OpenAI-backed)
FAITHFULNESS_EVAL_ENABLED=true
FAITHFULNESS_JUDGE_MODEL=gpt-4o-mini

# --- Récupération multi-doc / multi-périmètres -------------------------------
# Doc IDs ciblés (CSV). Laisser vide pour tous.
RETRIEVAL_DOC_IDS=

# Domaines ciblés (CSV), ex: rh,juridique,compta,technique
RETRIEVAL_DOMAINS=

# Nombre max de docs chargés en retrieval
RETRIEVAL_MAX_DOCS=20

# --- Sync Google Drive --------------------------------------------------------
DRIVE_FOLDER_ID=
GOOGLE_SERVICE_ACCOUNT_FILE=./secrets/google-service-account.json
DRIVE_SYNC_STATE_COLLECTION=sync_state

# --- Pont Frontend Next.js (Vstorm UI) ---------------------------------------
# Dans le frontend Next.js: NEXT_PUBLIC_API_URL=http://localhost:8000
# BACKEND_URL=http://localhost:8000
